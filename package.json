{
    "name": "docx-tmpl",
    "module": "index.ts",
    "type": "module",
    "scripts": {
        "start": "bun run index.ts",
        "dev": "bun run --watch index.ts",
        "build:prod": " bun build --compile --baseline --minify --sourcemap ./index.ts ./public/* --outfile dist/docx-tmpl",
        "build:linux:arm64": " bun build --compile --target=bun-linux--arm64 --minify --sourcemap  ./index.ts ./public/* --outfile dist/docx-tmpl-linux-arm64",
        "build:linux:amd64": " bun build --compile --target=bun-linux--amd64 --minify --sourcemap  ./index.ts ./public/* --outfile dist/docx-tmpl-linux-amd64",
        "build:darwin:arm64": " bun build --compile --target=bun-darwin-arm64 --minify --sourcemap  ./index.ts ./public/* --outfile dist/docx-tmpl-darwin-arm64"
    },
    "private": true,
    "devDependencies": {
        "@types/bun": "^1.3.10"
    },
    "peerDependencies": {
        "typescript": "^5.9.2"
    },
    "dependencies": {
        "docx-tmpl": ".",
        "easy-template-x": "file:../easy-template-x",
        "easy-template-x-angular-expressions": "0.2.2"
    }
}
